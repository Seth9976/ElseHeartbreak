				Sebastian "Ok"

			"Vad då för grejer?":
				Hank "Typ små saker som du har, jag vet inte riktigt"
				Sebastian "Ok"
		}
		GOTO SKIP_ALL

	"Vad ska jag egentligen ha all den här programmeringen till, jag fattar inte riktigt!":
		Hank "Man måste ju lära sig grunderna innan man kan göra de häftiga sakerna"
		CHOICE {
			"Ja men hur kan det spela roll vilken färg som en liten kub har?":
				Hank "Det är ju bara ett exempel för att du ska kunna lära dig"
				Hank "Dessutom tycker jag den är fin när den lyser"
				CHOICE {
					"Jo det är den ju":
					"Hmm, ja jag fattar":
				}
			"Ok, jag tror jag förstår... men det är så svårt bara":
				Hank "Ja, du kanske måste sova på saken"
				Hank "Eller ta en promenad"
				Hank "Det brukar hjälpa mig när jag ska fatta krångliga saker"
				CHOICE {
					"Ok, jag ska testa det":
					"Haha, verkligen?":
						Hank "Ja, det är sant"
				}
		}
		GOTO SKIP_ALL

	"Vem är egentligen bäst i stan på att programmera?":
		Hank "Vilken fråga... hur ska jag veta det?"
		Hank "Det är inte jag i alla fall, hehe"
		Hank "Kanske hon som leder forskningen på ministeriet?"
		CHOICE {
			"Ok":
			"Vem är det?":
				Hank "Jag vet inte så noga"
				Hank "Men folk brukar säga att hon är sjukt smart"
