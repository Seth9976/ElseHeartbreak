LISTEN Sebastian_talk_Hank
FOCUS
Hank.StartTalking()

Hank "Tja, hur har det gått med programmerandet?!"

CHOICE {
	"Det har gått rätt bra":
		Hank "Vad roligt att höra!"

	"Vet inte, kom av mig lite där efter vi sågs":
		Hank "Jaha, vad synd"
}

Hank "Är du sugen på att lära dig lite mer, jag har en lucka nu tror jag"

CHOICE {
	"Ja, jättegärna!":
		[LETS_GO]
		IF Hank.IsInRoom(HanksApartment) {
			Hank "Ok, gött"
		} ELSE {
			Hank "Ok, kom med"
		}
	"Kan vi ta det imorgon istället?":
		Hank "Visst, det funkar"
		Hank "L8rs"
		Hank.StopTalking()
		DEFOCUS

		IF IsDay() {
			WAIT IsNight()
			WAIT IsDay()
		}
		ELSE {
			WAIT IsDay()
		}

		[BOTHER_AGAIN]
		LISTEN Sebastian_talk_Hank
		Hank.StartTalking()
		Hank "Ja?"
		FOCUS
		CHOICE ETERNAL {
			"Har du tid med den där lektionen nu?":
				Hank "Visst, visst"
				GOTO LETS_GO
			"Äh, det var inget viktigt":
				Hank "Ok, l8rs"
				Hank.StopTalking()
				DEFOCUS
				GOTO BOTHER_AGAIN
		}
}

