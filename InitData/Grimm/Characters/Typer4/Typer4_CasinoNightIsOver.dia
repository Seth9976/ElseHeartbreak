Sebastian.SetKnowledge("Typer4Shoes")
WAIT Sebastian.IsNotInRoom(Lodge_Entry)



LISTEN Sebastian_talk_Typer4
Typer4.StartTalking()
FOCUS

Typer4 "Nå, hur gick det?"
Typer4 "Jag kräver att få byta de här"

CHOICE {
    "Tyvärr, vi tillåter inga byten":
        Typer4 "Det var det grövsta!"
        Typer4 "Jag ska anmäla er till polisen, det ska jag"
    "Var god och gå upp till affären där uppe så kan expediten hjälpa dig där":
        Typer4 "Men jag har redan pratat med henne!"
        Typer4 "Hon var till ingen nytta alls"
    "Skulle ni kunna komma tillbaka nästa vecka?":
        Typer4 "Nästa vecka?!"
        Typer4 "Vad har ni för service på det här stället"
}

