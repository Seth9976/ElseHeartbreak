    "Hej!":
    "God dag":
    "God morgon":
}

CHOICE {
    "Vad gör ni här?":
    "Söker ni någon?":
    "Vad är ert ärende?":
}

Typer4 "Jag vill tala med er chef!"

CHOICE {
    "Han är inte inne":
    "Hmm, jag ska se vad jag kan göra":
        Typer4 "Det är mycket brådskande!"
    "Eh...":
}

Typer4 "Ni ligger mycket illa till vill jag lova!"

Typer4 "Jag köpte ett par skor här förra veckan"
Typer4 "Uppe på skoaffären alltså"

Typer4 "Och de har redan gått sönder"

CHOICE {
    "Eh... jaha! Oj då":
    "Det var dåligt":
    "Verkligen?!":
    "Ööhh.......":
}

[AGAIN]
CHOICE {
    "Jag ska se vad jag kan göra":
