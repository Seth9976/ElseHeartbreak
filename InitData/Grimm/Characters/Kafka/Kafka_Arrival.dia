#		Typer1.StopWaitForGift()
#		Petra.StopWaitForGift()
#		Gunnar.StopWaitForGift()
#		Ivan.StopWaitForGift()
}

[BYE]
Kafka "Hej då!"

Kafka.StopTalking()
DEFOCUS

LISTEN Sebastian_talk_Kafka
FOCUS
Kafka.StartTalking()
Kafka "Ville du nåt?"
GOTO ANYTHING_ELSE

