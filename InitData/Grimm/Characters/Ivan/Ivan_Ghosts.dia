# (spöken ska kunna gå från nästan verkliga uppenbarelser med bara lite transparens till helt immateriella som bara kastar skuggbilder på väggarna runt sig)

[CHEAT]
CHOICE {
	"Jag är inte Pixie":
	"Men jag är Sebastian":
	"Är det du, Ivan?":
}

# Ivan.Mood("Angry")
Sebastian.SetKnowledge("IvanIsGhost")

Sebastian.Sleep(5)
WAIT 1
Ivan.Interact(Hotel_Room1_FuseBox)

WAIT 10

#Ivan.Interact(Hotel_Room1_Door1)
#WAIT Ivan.IsInRoom(Hotel_Corridor)
Ivan.Pos(Ivan_Ghost_Point)
Ivan.SetTimetable("Ivan_Ghost")

