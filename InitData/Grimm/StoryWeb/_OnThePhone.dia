
# sebastian sitter med sin mor och far vid middagsbordet
# klassisk musik hörs i bakgrunden
# kameran åker runt dem långsamt
# pappan pratar om något ointressant
# telefonen ringer plötsligt

BROADCAST SlowFadeIn

SetClock(0, 18, 45, 0)
SetClockSpeed(30)

Father.Pos(DadsChair)
#Father.SetHandItem(HomeApartment_CinnamonBun_CinnamonBun_3)

Mother.Pos(MomsChair)
Sebastian.Pos(SebastiansChair)

#WAIT 1
FOCUS


#GOTO AFTER_CHEAT_MENU
